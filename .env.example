# =============================================================================
# Opportunity Hunter — environment variables
# =============================================================================
# Copy this file to `.env.local` (for the Next.js dev server) and fill in
# the values from your Supabase project:
#   https://app.supabase.com/project/_/settings/api
#
# NEVER commit a real `.env.local`. It is git-ignored on purpose.
# =============================================================================

# --- Public (exposed to the browser) ----------------------------------------
# These two are required for Supabase to work. They are safe to ship in
# the JS bundle; Supabase enforces RLS at the database level.

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# --- Server-only (NEVER prefix with NEXT_PUBLIC_) ---------------------------
# Used by background jobs, server actions, and the seed script. Grants
# full read/write access to the database and bypasses RLS.

SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_SECRET"

# Optional: direct Postgres connection string. Useful for the Supabase
# CLI (`supabase db reset`) or for running raw migrations from your
# machine. Format:
#   postgresql://postgres:password@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_DB_URL=""

# --- External API Keys (optional) -------------------------------------------
# These are used by source providers to fetch data from external platforms.
# If not set, the corresponding source will be skipped gracefully.

# Product Hunt API token (Developer Token from https://www.producthunt.com/v2/oauth/applications)
PRODUCT_HUNT_TOKEN=""

# Twitter/X API Bearer Token (from https://developer.twitter.com/en/portal/dashboard)
TWITTER_BEARER_TOKEN=""

# IndieHackers API Key (unofficial RSS feed access)
INDIEHACKERS_API_KEY=""

# --- Email Notifications (Resend) -------------------------------------------
# Used by the Sprint 44 email pipeline. Get your API key from
# https://resend.com/api-keys

RESEND_API_KEY=""
EMAIL_FROM=""
