{
  "name": "opportunity-hunter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:types": "supabase gen types typescript --local > src/types/database.types.ts",
    "db:reset": "supabase db reset",
    "db:seed": "psql \"$SUPABASE_DB_URL\" -f supabase/seed/00_reset.sql && for f in supabase/seed/0[1-6]*.sql; do psql \"$SUPABASE_DB_URL\" -f \"$f\"; done",
    "reddit": "tsx src/scripts/reddit.ts",
    "pain-points": "tsx src/scripts/pain-points.ts",
    "clusters": "tsx src/scripts/clusters.ts",
    "opportunities": "tsx src/scripts/opportunities.ts",
    "startup-ideas": "tsx src/scripts/startup-ideas.ts",
    "pipeline": "tsx src/scripts/pipeline.ts",
    "job:reddit": "tsx src/jobs/reddit.job.ts",
    "job:pipeline": "tsx src/jobs/pipeline.job.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.16",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.108.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "openai": "^6.42.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.14.0",
    "server-only": "^0.0.1",
    "stripe": "^22.2.2",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
